{
  "manifest_version": 3,
  "name": "Fake Guru Buster",
  "version": "1.0.1",
  "description": "AI fact-checker that exposes misleading YouTube claims with real evidence",

  "permissions": ["activeTab", "scripting", "storage", "tabs"],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*.vercel.app/*"
  ],

  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/content/detector.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_title": "Fake Guru Buster",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "src/sidebar/index.html",
        "src/sidebar/sidebar.css",
        "src/sidebar/sidebar.js"
      ],
      "matches": ["https://www.youtube.com/*"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
