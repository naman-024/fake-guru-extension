# Groq — free at console.groq.com
GROQ_API_KEY=gsk_...

# YouTube Data API v3 — console.cloud.google.com
YOUTUBE_API_KEY=AIza...

# Brave Search — free tier at api.search.brave.com (used for fact-checking web evidence)
# Optional — analysis still works without it, just without live web citations
BRAVE_SEARCH_API_KEY=BSA...

# Supadata — free tier at supadata.ai (YouTube transcript fetching)
# Optional — falls back to a free public endpoint if not set
SUPADATA_API_KEY=
